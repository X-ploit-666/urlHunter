#!/usr/bin/bash
# ============================================================
# URLHunter
# Automated URL Discovery & XSS Recon Pipeline
#
# Author  : X-ploit-666
# Version : 1.0.0
# GitHub  : https://github.com/X-ploit-666
# ============================================================

set -euo pipefail
VERSION="1.0.0"
source colors.sh
trap 'echo -e "\n${red}[!] Interrupted by user${reset}"; exit 1' INT

echo -e "${cyan}URLHunter v${VERSION}${reset}"

echo -e "${dim}==============================================${reset}"
echo -e "${red}${bold}"
toilet -f standard "URLHunter"
echo -e "${reset}"
echo -e "${dim}==============================================${reset}"
echo -e "${dim}Automated URL Discovery & XSS Recon Pipeline${reset}"
echo ""
# Checks
if [[ $# -ne 1 || ! -f $1 ]]; then
    echo -e "${red}[!] Usage${reset}\n$0 <domains-file.txt>"
    exit 1
fi 

input=$1
OUTPUT_DIR="output"
mkdir -p "$OUTPUT_DIR"

tools=(
waybackurls
gau
httpx
katana
gf
uro
Gxss
kxss
dalfox
)

echo -e "${cyan}[+]${reset} Checking dependencies..."

for tool in "${tools[@]}"; do
    if ! command -v "$tool" &>/dev/null; then
        echo -e "${red}[!] Missing dependency: $tool${reset}"
        exit 1
    fi
done

echo -e "${green}[✓]${reset} All dependencies installed"
echo ""

rm -f "$OUTPUT_DIR"/*.txt 2>/dev/null || true
final_count=0

## URL Collection Phase
echo -e "${cyan}[+]${reset} Gathering Links From Targets..."

# Collect historical URLs from Wayback Machine
echo -e "${cyan}[+]${reset} Gathering URLs From waybackurls..."
waybackurls < "$input" 2>/dev/null > "$OUTPUT_DIR/wayback_urls.txt"
wayback_count=$(wc -l < "$OUTPUT_DIR/wayback_urls.txt")
echo -e "${green}[✓]${reset} $wayback_count URLs gathered and saved in $OUTPUT_DIR/wayback_urls.txt"
echo ""

# Collect additional URLs from GAU (GetAllUrls)
echo -e "${cyan}[+]${reset} Gathering URLs From gau..."
gau < "$input" 2>/dev/null > "$OUTPUT_DIR/gau.txt"
gau_count=$(wc -l < "$OUTPUT_DIR/gau.txt")
echo -e "${green}[✓]${reset} $gau_count URLs gathered and saved in $OUTPUT_DIR/gau.txt"
echo ""


## URL Normalization and Deduplication
echo -e "${cyan}[+]${reset} Combining All Gathered URLs..."
cat "$OUTPUT_DIR/wayback_urls.txt" "$OUTPUT_DIR/gau.txt" | sort -u > "$OUTPUT_DIR/all_urls.txt"
unique_count=$(wc -l < "$OUTPUT_DIR/all_urls.txt")

echo -e "${green}[✓]${reset} $unique_count unique URLs saved in $OUTPUT_DIR/all_urls.txt"
echo ""

## Target Scope Validation
echo -e "${cyan}[+]${reset} Filtering In-Scope URLs..."
> "$OUTPUT_DIR/scoped_urls.txt"

while read -r domain; do

    # Skip empty lines and comments
    [[ -z "$domain" ]] && continue
    [[ "$domain" =~ ^# ]] && continue

    # Remove protocol and trailing slash
    domain=$(echo "$domain" | sed -E 's#https?://##; s#/.*##; s#/$##')
    # Escape dots for regex safety
    domain=$(echo "$domain" | sed 's/\./\\./g')

    grep -E "https?://([a-zA-Z0-9-]+\.)*${domain}(/|$)" \
    "$OUTPUT_DIR/all_urls.txt" >> "$OUTPUT_DIR/scoped_urls.txt" || true
done < "$input"

sort -u "$OUTPUT_DIR/scoped_urls.txt" -o "$OUTPUT_DIR/scoped_urls.txt"
scope_count=$(wc -l < "$OUTPUT_DIR/scoped_urls.txt")
echo -e "${green}[✓]${reset} $scope_count URLs are in scope and saved in $OUTPUT_DIR/scoped_urls.txt"

echo ""

## Live Host Verification
echo -e "${cyan}[+]${reset} Checking for Live URLs..."
cat "$OUTPUT_DIR/scoped_urls.txt" \
| httpx -silent -mc 200,301,302,307,308,401,403,429 \
| sort -u > "$OUTPUT_DIR/live_urls.txt"
live_count=$(wc -l < "$OUTPUT_DIR/live_urls.txt")
echo -e "${green}[✓]${reset} $live_count live URLs saved in $OUTPUT_DIR/live_urls.txt"
echo ""



if [[ ! -s "$OUTPUT_DIR/live_urls.txt" ]]; then
    echo -e "${red}[!]${reset} No live URLs found."
    exit 0
fi

## Active Crawling and Endpoint Discovery
echo -e "${cyan}[+]${reset} Crawling Live URLs With Katana..."
katana -list "$OUTPUT_DIR/live_urls.txt" -jc -d 3 -kf all -silent -o "$OUTPUT_DIR/katana.txt" 2>/dev/null
# alternative: suppress all katana output
if [[ -f "$OUTPUT_DIR/katana.txt" ]]; then
    katana_count=$(wc -l < "$OUTPUT_DIR/katana.txt")
else
    katana_count=0
    touch "$OUTPUT_DIR/katana.txt"
fi

echo -e "${green}[✓]${reset} $katana_count URLs gathered and saved in $OUTPUT_DIR/katana.txt"
echo ""

## Merge Crawled and Discovered URLs
cat "$OUTPUT_DIR/live_urls.txt" "$OUTPUT_DIR/katana.txt" | sort -u > "$OUTPUT_DIR/katana_merge.txt"

> "$OUTPUT_DIR/final_live_urls.txt"

while read -r domain; do
    [[ -z "$domain" ]] && continue
    [[ "$domain" =~ ^# ]] && continue
    domain=$(echo "$domain" | sed -E 's#https?://##; s#/.*##; s#/$##')
    domain=$(echo "$domain" | sed 's/\./\\./g')
    grep -E "https?://([a-zA-Z0-9-]+\.)*${domain}(/|$)" "$OUTPUT_DIR/katana_merge.txt" >> "$OUTPUT_DIR/final_live_urls.txt" || true
done < "$input"

sort -u "$OUTPUT_DIR/final_live_urls.txt" -o "$OUTPUT_DIR/final_live_urls.txt"
rm "$OUTPUT_DIR/katana_merge.txt"
live_count=$(wc -l < "$OUTPUT_DIR/final_live_urls.txt")
echo -e "${green}[✓]${reset} $live_count total live URLs after Katana saved in $OUTPUT_DIR/final_live_urls.txt"
echo ""


## XSS Parameter Discovery Pipeline
echo -e "${magenta}[⚡]${reset} Preparing URLs for XSS..."

> "$OUTPUT_DIR/dalfox_targets.txt"

cat "$OUTPUT_DIR/final_live_urls.txt" \
| gf xss \
| uro \
| sort -u \
| Gxss \
| kxss \
| tee "$OUTPUT_DIR/xss_output.txt"


if [ -s "$OUTPUT_DIR/xss_output.txt" ]; then
    grep -oP 'https?://\S+' "$OUTPUT_DIR/xss_output.txt" \
    | sed 's/=.*/=/' \
    | sort -u > "$OUTPUT_DIR/dalfox_targets.txt"

    final_count=$(wc -l < "$OUTPUT_DIR/dalfox_targets.txt")
    echo -e "${green}[✓]${reset} $final_count URLs ready for Dalfox saved in $OUTPUT_DIR/dalfox_targets.txt"

else
    echo -e "${red}[-] No URLs extracted from XSS output.${reset}"
fi

if [[ -s "$OUTPUT_DIR/dalfox_targets.txt" ]]; then
    echo -e "${red}[☠]${reset} Starting Dalfox..."
    dalfox file "$OUTPUT_DIR/dalfox_targets.txt" -o "$OUTPUT_DIR/dalfox_results.txt" --silence || true
else
    echo -e "${red}[-] No Dalfox targets found.${reset}"
    exit 0
fi

if [[ -s "$OUTPUT_DIR/dalfox_results.txt" ]]; then
    echo -e "${red}[☠] XSS findings saved in $OUTPUT_DIR/dalfox_results.txt${reset}"
else
    echo -e "${green}[✓] No XSS findings detected${reset}"
fi


echo ""

## Execution Summary
echo -e "${cyan}"
figlet -f script "Summary"
echo -e "${reset}"
echo ""

echo -e "${cyan}$OUTPUT_DIR/wayback_urls.txt${reset} ---> ${green}$wayback_count URLs${reset}"
echo -e "${cyan}$OUTPUT_DIR/gau.txt${reset} ---> ${green}$gau_count URLs${reset}"
echo -e "${cyan}$OUTPUT_DIR/katana.txt${reset} ---> ${green}$katana_count URLs${reset}"
echo -e "${cyan}$OUTPUT_DIR/all_urls.txt${reset} ---> ${green}$unique_count unique URLs${reset}"
echo -e "${cyan}$OUTPUT_DIR/final_live_urls.txt${reset} ---> ${green}$live_count live URLs${reset}"
echo -e "${cyan}$OUTPUT_DIR/dalfox_targets.txt${reset} ---> ${green}$final_count XSS targets${reset}"
echo -e "${cyan}$OUTPUT_DIR/scoped_urls.txt${reset} ---> ${green}$scope_count in-scope URLs${reset}"

echo ""
echo -e "${dim}URLHunter v${VERSION} | X-ploit-666${reset}"
echo ""